#!/bin/bash
ip addr add 10.0.0.1/24 dev eth0
ip link set eth0 up

pip3 install p4runtime &>/dev/null

simple_switch_grpc --device-id 1 -i 1@eth0 \
    --p4runtime-server-addr 0.0.0.0:50051 \
    /shared/client.json &

python3 /shared/bridge.py 50001 50051 &

sleep 2
chmod +x /shared/ClientController/Client
/shared/ClientController/Client > /shared/client.log 2>&1 &