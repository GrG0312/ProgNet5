#!/bin/sh
(
    ip link set eth0 up
    ip link set eth1 up
    simple_switch --device-id 1 -i 1@eth0 -i 2@eth1 --log-console /shared/client.json &
    until echo exit | simple_switch_CLI --thrift-port 9090 > /dev/null 2>&1; do
        sleep 1
    done
    echo "mirroring_add 100 2" | simple_switch_CLI --thrift-port 9090
) &
