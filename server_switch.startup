#!/bin/bash
p4c --target bmv2 --arch v1model server.p4
simple_switch -i 1@eth0 --log-file /shared/server.log --log-flush --log-level info server.json &

while [[ $(pgrep simple_switch) -eq 0 ]]; do sleep 1; done
until simple_switch_CLI <<< "help"; do sleep 1; done

simple_switch_CLI <<< $(cat commands.txt)
